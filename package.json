{
  "name": "talk2sql",
  "version": "3.34.2",
  "description": "Talk2Sql — Oracle Fusion Desktop Explorer + ICM Hub + Ariadne + Base SQL Core + BI (catalog-driven report builder & dashboards on the learned schema)",
  "main": "main.js",
  "author": {
    "name": "Chandra Kasarabada"
  },
  "license": "MIT",
  "scripts": {
    "test": "node test/t2s-guard.test.js && node test/oauth-refresh.test.js && node test/bip-engine.test.js",
    "start": "electron .",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:all": "electron-builder --mac --win"
  },
  "build": {
    "appId": "com.ck.talk2sql",
    "productName": "Talk2Sql",
    "files": [
      "main.js",
      "preload.js",
      "oauth-manager.js",
      "renderer/**/*",
      "assets/**/*"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "darkModeSupport": true,
      "icon": "assets/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ]
    },
    "dmg": {
      "icon": "assets/icon.png"
    },
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "cskasarabada",
      "repo": "Talk2Sql"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
